# -----------------------------
# AI / LLM
# -----------------------------
OPENAI_KEY=
OLLAMA_KEY=
OLLAMA_BASE_URL=
MODEL=gpt-oss:120b-cloud

# -----------------------------
# Agent
# -----------------------------
AGENT_MAX_STEPS=10
AGENT_TEMPERATURE=0.0
AGENT_MAX_TOKENS=
AGENT_TIMEOUT_S=30.0
TRACING_ENABLED=true
TRACING_INCLUDE_QUERY_TEXT=true
# Optional override (uses long default prompt if empty)
# AGENT_SYSTEM_PROMPT=

# -----------------------------
# RAG
# -----------------------------
DEFAULT_CHUNKING_STRATEGY=fixed_window
RAG_COLLECTION_NAME=
RAG_TOP_K=12
RAG_PREFETCH_K=80
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_PDF_MAX_PAGES=300
RAG_PDF_MAX_MB=25
RAG_PDF_DEDUPE_THRESHOLD=96

RERANKER_ENABLED=false
RERANKER_MODEL=rerank-v4.0-fast
RERANKER_API_KEY=

EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BASE_URL=

# Optional override; default is <BASE_DIR>/data/chroma
# CHROMA_PERSIST_DIR=

SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.80

QUERY_REFINEMENT_ENABLED=true
QUERY_REFINEMENT_MAX_TOKENS=64
QUERY_REFINEMENT_TEMPERATURE=0.0

# -----------------------------
# Database
# -----------------------------
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
POSTGRES_DB=agentic_rag
POSTGRES_USER=admin
POSTGRES_PASSWORD=1512
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/agentic_rag

# -----------------------------
# Auth / JWT
# -----------------------------
ALGORITHM=HS256
ACCESS_TOKEN_SECRET_KEY=change_me
ACCESS_TOKEN_EXPIRE_TIME=30
REFRESH_TOKEN_SECRET_KEY=change_me
REFRESH_TOKEN_EXPIRE_TIME=10080
RESET_PASSWORD_TOKEN_SECRET=change_me
VERIFICATION_TOKEN_SECRET=change_me

ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/

# -----------------------------
# Evaluation
# -----------------------------
EVAL_JUDGE_MODEL=gpt-oss:120b-cloud
EVAL_JUDGE_MAX_TOKENS=600
EVAL_JUDGE_TIMEOUT_S=60.0
EVAL_MAX_CASES=500
EVAL_UPLOAD_MAX_MB=10
EVAL_POLL_INTERVAL_MS=2000
